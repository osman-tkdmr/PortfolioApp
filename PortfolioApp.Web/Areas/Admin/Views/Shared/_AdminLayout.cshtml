<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] – Portfolio Admin</title>
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <!-- Toastr -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <style>
        :root {
            --sidebar-width: 260px;
            --sidebar-bg: #2b2420;
            --sidebar-hover: #3a3129;
            --accent: #b0876a;
            --accent-hover: #96714f;
            --topbar-height: 56px;

            /* Bring Bootstrap's primary in line with the site's brand color */
            --bs-primary: #b0876a;
            --bs-primary-rgb: 176, 135, 106;
        }

        body { background: #f7f4f0; font-family: 'Segoe UI', sans-serif; }

        /* Retheme Bootstrap's primary buttons — CDN build bakes shades into
           the .btn-primary rule itself, so overriding --bs-primary alone isn't enough */
        .btn-primary {
            --bs-btn-bg: #b0876a; --bs-btn-border-color: #b0876a;
            --bs-btn-hover-bg: #96714f; --bs-btn-hover-border-color: #96714f;
            --bs-btn-active-bg: #7d5c40; --bs-btn-active-border-color: #7d5c40;
            --bs-btn-disabled-bg: #b0876a; --bs-btn-disabled-border-color: #b0876a;
            --bs-btn-focus-shadow-rgb: 176, 135, 106;
        }
        .btn-outline-primary {
            --bs-btn-color: #b0876a; --bs-btn-border-color: #b0876a;
            --bs-btn-hover-bg: #b0876a; --bs-btn-hover-border-color: #b0876a;
            --bs-btn-active-bg: #96714f; --bs-btn-active-border-color: #96714f;
            --bs-btn-focus-shadow-rgb: 176, 135, 106;
        }

        /* Sidebar */
        #sidebar {
            position: fixed; top: 0; left: 0; bottom: 0; width: var(--sidebar-width);
            background: var(--sidebar-bg); color: #cdd2e3; overflow-y: auto;
            z-index: 1000; transition: transform .25s;
        }
        #sidebar .brand {
            padding: 1.25rem 1.5rem; font-size: 1.2rem; font-weight: 700;
            color: #fff; border-bottom: 1px solid rgba(255,255,255,.08);
            display: flex; align-items: center; gap: .75rem;
        }
        #sidebar .brand span { color: var(--accent); }
        #sidebar .nav-group-title {
            font-size: .7rem; text-transform: uppercase; letter-spacing: .1em;
            color: rgba(255,255,255,.4); padding: .75rem 1.5rem .25rem;
        }
        #sidebar .nav-link {
            padding: .6rem 1.5rem; color: rgba(255,255,255,.7); display: flex;
            align-items: center; gap: .6rem; font-size: .9rem; border-radius: 0;
            transition: background .15s, color .15s;
        }
        #sidebar .nav-link:hover, #sidebar .nav-link.active {
            background: var(--sidebar-hover); color: #fff;
            border-left: 3px solid var(--accent);
        }
        #sidebar .nav-link i { width: 18px; text-align: center; }

        /* Topbar */
        #topbar {
            position: fixed; top: 0; left: var(--sidebar-width); right: 0;
            height: var(--topbar-height); background: #fff;
            border-bottom: 1px solid #e9ecef; z-index: 999;
            display: flex; align-items: center; padding: 0 1.5rem;
            gap: 1rem;
        }
        #topbar .page-title { font-weight: 600; font-size: 1rem; color: #333; margin: 0; flex: 1; }

        /* Content */
        #main-content { margin-left: var(--sidebar-width); padding-top: calc(var(--topbar-height) + 1.5rem); min-height: 100vh; }
        .content-wrapper { padding: 0 1.5rem 2rem; }

        /* Cards */
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.06); }
        .card-header { background: transparent; border-bottom: 1px solid #f0f0f0; font-weight: 600; }

        /* Stat cards */
        .stat-card { border-radius: 16px; padding: 1.5rem; color: #fff; overflow: hidden; position: relative; }
        .stat-card .stat-icon { font-size: 2.5rem; opacity: .25; position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); }

        /* Responsive */
        @@media (max-width: 768px) {
            #sidebar { transform: translateX(-100%); }
            #sidebar.open { transform: none; }
            #topbar, #main-content { left: 0; margin-left: 0; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- Sidebar -->
<nav id="sidebar">
    <div class="brand">
        <i class="fa fa-code"></i>
        Portfolio<span>CMS</span>
    </div>

    <div class="nav-group-title">Ana Menü</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
       asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
        <i class="fa fa-gauge-high"></i> Dashboard
    </a>

    <div class="nav-group-title">İçerik</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" ? "active" : "")"
       asp-area="Admin" asp-controller="Blog" asp-action="Index">
        <i class="fa fa-newspaper"></i> Blog Yazıları
    </a>
    <a class="nav-link" asp-area="Admin" asp-controller="Blog" asp-action="Categories">
        <i class="fa fa-folder"></i> Blog Kategorileri
    </a>
    <a class="nav-link" asp-area="Admin" asp-controller="Blog" asp-action="Tags">
        <i class="fa fa-tags"></i> Blog Etiketleri
    </a>

    <div class="nav-group-title">Portföy</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hero" ? "active" : "")"
       asp-area="Admin" asp-controller="Hero" asp-action="Index">
        <i class="fa fa-star"></i> Hero Bölümü
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "About" ? "active" : "")"
       asp-area="Admin" asp-controller="About" asp-action="Index">
        <i class="fa fa-user"></i> Hakkımda
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Experience" ? "active" : "")"
       asp-area="Admin" asp-controller="Experience" asp-action="Index">
        <i class="fa fa-briefcase"></i> Deneyim
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Education" ? "active" : "")"
       asp-area="Admin" asp-controller="Education" asp-action="Index">
        <i class="fa fa-graduation-cap"></i> Eğitim
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Skill" ? "active" : "")"
       asp-area="Admin" asp-controller="Skill" asp-action="Index">
        <i class="fa fa-bars-progress"></i> Yetenekler
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Certificate" ? "active" : "")"
       asp-area="Admin" asp-controller="Certificate" asp-action="Index">
        <i class="fa fa-certificate"></i> Sertifikalar
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Language" ? "active" : "")"
       asp-area="Admin" asp-controller="Language" asp-action="Index">
        <i class="fa fa-language"></i> Diller
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Achievement" ? "active" : "")"
       asp-area="Admin" asp-controller="Achievement" asp-action="Index">
        <i class="fa fa-trophy"></i> Başarılar
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Project" ? "active" : "")"
       asp-area="Admin" asp-controller="Project" asp-action="Index">
        <i class="fa fa-diagram-project"></i> Projeler
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Testimonial" ? "active" : "")"
       asp-area="Admin" asp-controller="Testimonial" asp-action="Index">
        <i class="fa fa-comments"></i> Referanslar
    </a>

    <div class="nav-group-title">Site Yönetimi</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Menu" ? "active" : "")"
       asp-area="Admin" asp-controller="Menu" asp-action="Index">
        <i class="fa fa-bars"></i> Menü
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SocialMedia" ? "active" : "")"
       asp-area="Admin" asp-controller="SocialMedia" asp-action="Index">
        <i class="fa fa-share-nodes"></i> Sosyal Medya
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Footer" ? "active" : "")"
       asp-area="Admin" asp-controller="Footer" asp-action="Index">
        <i class="fa fa-shoe-prints"></i> Footer
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contact" ? "active" : "")"
       asp-area="Admin" asp-controller="Contact" asp-action="Info">
        <i class="fa fa-address-book"></i> İletişim Bilgisi
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SiteSettings" ? "active" : "")"
       asp-area="Admin" asp-controller="SiteSettings" asp-action="Index">
        <i class="fa fa-sliders"></i> Site Ayarları
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Seo" ? "active" : "")"
       asp-area="Admin" asp-controller="Seo" asp-action="Index">
        <i class="fa fa-magnifying-glass-chart"></i> SEO
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Theme" ? "active" : "")"
       asp-area="Admin" asp-controller="Theme" asp-action="Index">
        <i class="fa fa-palette"></i> Tema Yönetimi
    </a>

    <div class="nav-group-title">Raporlar</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analytics" ? "active" : "")"
       asp-area="Admin" asp-controller="Analytics" asp-action="Index">
        <i class="fa fa-chart-line"></i> Ziyaretçi Analizi
    </a>
    <a class="nav-link" asp-area="Admin" asp-controller="Contact" asp-action="Index">
        <i class="fa fa-envelope"></i> Mesajlar
    </a>

    <div style="height: 2rem;"></div>
</nav>

<!-- Topbar -->
<header id="topbar">
    <button class="btn btn-sm btn-outline-secondary d-md-none" id="sidebarToggle">
        <i class="fa fa-bars"></i>
    </button>
    <h6 class="page-title">@(ViewData["Title"] ?? "Dashboard")</h6>
    <a href="/" target="_blank" class="btn btn-sm btn-outline-primary">
        <i class="fa fa-eye me-1"></i>Siteyi Gör
    </a>
    <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-sm btn-outline-danger">
            <i class="fa fa-right-from-bracket me-1"></i>Çıkış
        </button>
    </form>
</header>

<!-- Main Content -->
<main id="main-content">
    <div class="content-wrapper">
        @if (TempData["Success"] is string successMsg)
        {
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
                <i class="fa fa-circle-check"></i>
                <span>@successMsg</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] is string errorMsg)
        {
            <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
                <i class="fa fa-circle-exclamation"></i>
                <span>@errorMsg</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>
</main>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>

<script>
    // Sidebar mobile toggle
    document.getElementById('sidebarToggle')?.addEventListener('click', () => {
        document.getElementById('sidebar').classList.toggle('open');
    });

    // Preserve sidebar scroll position across full page navigations
    (function () {
        const sidebar = document.getElementById('sidebar');
        if (!sidebar) return;

        const savedScroll = sessionStorage.getItem('adminSidebarScroll');
        if (savedScroll !== null) {
            sidebar.scrollTop = parseInt(savedScroll, 10) || 0;
        }

        sidebar.addEventListener('click', (e) => {
            if (e.target.closest('a')) {
                sessionStorage.setItem('adminSidebarScroll', sidebar.scrollTop);
            }
        });
    })();

    // DataTables defaults
    $(document).ready(function () {
        $('.datatable').DataTable({
            language: {
                url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/tr.json'
            },
            order: [[0, 'desc']],
            pageLength: 25
        });
    });

    // Generic AJAX delete with SweetAlert2
    $(document).on('click', '.btn-delete', function (e) {
        e.preventDefault();
        const url = $(this).data('url');
        const name = $(this).data('name') || 'bu kaydı';
        Swal.fire({
            title: 'Emin misiniz?',
            text: `"${name}" silinecek. Bu işlem geri alınamaz.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'İptal'
        }).then(result => {
            if (result.isConfirmed) {
                $.post(url, { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() })
                    .done(() => { Swal.fire('Silindi!', '', 'success').then(() => location.reload()); })
                    .fail(() => Swal.fire('Hata!', 'Bir hata oluştu.', 'error'));
            }
        });
    });

    // Toastr configuration
    toastr.options = { positionClass: 'toast-top-right', timeOut: 3000, closeButton: true };
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
