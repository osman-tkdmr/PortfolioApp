@model PortfolioApp.DTO.DTOs.Site.TestimonialCreateDto
@{
    ViewData["Title"] = "Yeni Referans";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="fa fa-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">Yeni Referans</h5>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" asp-action="Create" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Yazar Adı *</label>
                    <input asp-for="AuthorName" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Unvan</label>
                    <input asp-for="AuthorTitle" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Şirket</label>
                    <input asp-for="AuthorCompany" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Puan (1-5)</label>
                    <input asp-for="Rating" type="number" min="1" max="5" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">İçerik *</label>
                    <textarea asp-for="Content" class="form-control" rows="4" required></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Yazar Fotoğrafı</label>
                    <input type="file" name="avatar" class="form-control" accept="image/*" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Sıra</label>
                    <input asp-for="DisplayOrder" type="number" class="form-control" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input asp-for="IsApproved" class="form-check-input" role="switch" />
                        <label asp-for="IsApproved" class="form-check-label">Onaylı</label>
                    </div>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input asp-for="IsFeatured" class="form-check-input" role="switch" />
                        <label asp-for="IsFeatured" class="form-check-label">Öne Çıkan</label>
                    </div>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" role="switch" />
                        <label asp-for="IsActive" class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="fa fa-floppy-disk me-1"></i>Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>
