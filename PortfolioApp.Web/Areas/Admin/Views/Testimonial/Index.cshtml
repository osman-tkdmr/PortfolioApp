@model IList<PortfolioApp.DTO.DTOs.Site.TestimonialDto>
@{
    ViewData["Title"] = "Referanslar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-bold"><i class="fa fa-quote-left me-2 text-primary"></i>Referanslar</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fa fa-plus me-1"></i>Yeni Ekle</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="dataTable">
            <thead class="table-light">
                <tr><th>Yazar</th><th>Unvan / Şirket</th><th>Puan</th><th>Durum</th><th>İşlem</th></tr>
            </thead>
            <tbody>
                @foreach (var item in Model ?? [])
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(item.AuthorImageUrl))
                                {
                                    <img src="@item.AuthorImageUrl" width="32" height="32" class="rounded-circle" style="object-fit:cover" />
                                }
                                <span class="fw-semibold">@item.AuthorName</span>
                            </div>
                        </td>
                        <td>@item.AuthorTitle @(item.AuthorCompany is not null ? $"/ {item.AuthorCompany}" : "")</td>
                        <td>
                            @for (int i = 0; i < item.Rating; i++) { <i class="fa fa-star text-warning fa-sm"></i> }
                        </td>
                        <td><span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">@(item.IsActive ? "Aktif" : "Pasif")</span></td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Düzenle"><i class="fa fa-pen"></i></a>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteItem(@item.Id)" title="Sil"><i class="fa fa-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
function deleteItem(id) {
    Swal.fire({ title: 'Silmek istediğinize emin misiniz?', icon: 'warning', showCancelButton: true, confirmButtonText: 'Evet, Sil', cancelButtonText: 'İptal', confirmButtonColor: '#dc3545' }).then(r => {
        if (!r.isConfirmed) return;
        fetch(`/Admin/Testimonial/Delete/${id}`, { method: 'POST', headers: { 'RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]').value } }).then(() => location.reload());
    });
}
</script>
}
