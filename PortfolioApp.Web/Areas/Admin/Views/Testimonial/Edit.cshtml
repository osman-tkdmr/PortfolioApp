@model PortfolioApp.DTO.DTOs.Site.TestimonialDto
@{
    ViewData["Title"] = "Referans Düzenle";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="fa fa-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">Referans Düzenle</h5>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" asp-action="Edit" asp-route-id="@Model.Id" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Yazar Adı *</label>
                    <input asp-for="AuthorName" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Unvan</label>
                    <input asp-for="AuthorTitle" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Şirket</label>
                    <input asp-for="AuthorCompany" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Puan (1-5)</label>
                    <input asp-for="Rating" type="number" min="1" max="5" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">İçerik *</label>
                    <textarea asp-for="Content" class="form-control" rows="4" required></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Yazar Fotoğrafı</label>
                    @if (!string.IsNullOrEmpty(Model.AuthorImageUrl))
                    {
                        <div class="mb-2"><img src="@Model.AuthorImageUrl" class="rounded-circle" width="64" height="64" style="object-fit:cover" /></div>
                    }
                    <input type="file" name="avatar" class="form-control" accept="image/*" />
                    <input type="hidden" asp-for="AuthorImageUrl" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Sıra</label>
                    <input asp-for="DisplayOrder" type="number" class="form-control" />
                </div>
                <div class="col-md-8 d-flex align-items-end gap-4">
                    <div class="form-check form-switch"><input asp-for="IsApproved" class="form-check-input" role="switch" /><label asp-for="IsApproved" class="form-check-label">Onaylı</label></div>
                    <div class="form-check form-switch"><input asp-for="IsFeatured" class="form-check-input" role="switch" /><label asp-for="IsFeatured" class="form-check-label">Öne Çıkan</label></div>
                    <div class="form-check form-switch"><input asp-for="IsActive" class="form-check-input" role="switch" /><label asp-for="IsActive" class="form-check-label">Aktif</label></div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="fa fa-floppy-disk me-1"></i>Güncelle</button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>
