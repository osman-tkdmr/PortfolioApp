@model PortfolioApp.DTO.DTOs.Dashboard.DashboardStatsDto
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card" style="background: linear-gradient(135deg,#b0876a,#96714f)">
            <div class="fw-bold fs-2">@Model?.TotalProjects</div>
            <div class="small opacity-75">Toplam Proje</div>
            <i class="fa fa-diagram-project stat-icon"></i>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card" style="background: linear-gradient(135deg,#c08d7f,#a5695c)">
            <div class="fw-bold fs-2">@Model?.TotalBlogPosts</div>
            <div class="small opacity-75">Blog Yazısı</div>
            <i class="fa fa-newspaper stat-icon"></i>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card" style="background: linear-gradient(135deg,#c9a06a,#b0854c)">
            <div class="fw-bold fs-2">@Model?.UnreadMessages</div>
            <div class="small opacity-75">Okunmamış Mesaj</div>
            <i class="fa fa-envelope stat-icon"></i>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card" style="background: linear-gradient(135deg,#8a9a7e,#6f8064)">
            <div class="fw-bold fs-2">@Model?.TodayVisitors</div>
            <div class="small opacity-75">Bugünkü Ziyaretçi</div>
            <i class="fa fa-eye stat-icon"></i>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Visitor Chart -->
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span><i class="fa fa-chart-line me-2 text-primary"></i>Son 30 Gün Ziyaretçi</span>
                <span class="badge bg-primary-subtle text-primary">Toplam: @Model?.TotalVisitors</span>
            </div>
            <div class="card-body">
                <canvas id="visitorChart" style="max-height:280px"></canvas>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header"><i class="fa fa-bolt me-2 text-warning"></i>Hızlı İşlemler</div>
            <div class="card-body p-3">
                <div class="d-grid gap-2">
                    <a asp-area="Admin" asp-controller="Blog" asp-action="Create" class="btn btn-outline-primary btn-sm text-start">
                        <i class="fa fa-pen me-2"></i>Yeni Blog Yazısı
                    </a>
                    <a asp-area="Admin" asp-controller="Project" asp-action="Create" class="btn btn-outline-success btn-sm text-start">
                        <i class="fa fa-plus me-2"></i>Yeni Proje
                    </a>
                    <a asp-area="Admin" asp-controller="Theme" asp-action="Index" class="btn btn-outline-secondary btn-sm text-start">
                        <i class="fa fa-palette me-2"></i>Tema Değiştir
                        @if (Model?.ActiveThemeName is not null)
                        {
                            <span class="badge bg-secondary ms-1">@Model.ActiveThemeName</span>
                        }
                    </a>
                    <a asp-area="Admin" asp-controller="Contact" asp-action="Index" class="btn btn-outline-warning btn-sm text-start">
                        <i class="fa fa-inbox me-2"></i>Mesajlar
                        @if (Model?.UnreadMessages > 0)
                        {
                            <span class="badge bg-warning text-dark ms-1">@Model.UnreadMessages</span>
                        }
                    </a>
                    <a asp-area="Admin" asp-controller="SiteSettings" asp-action="Index" class="btn btn-outline-info btn-sm text-start">
                        <i class="fa fa-sliders me-2"></i>Site Ayarları
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Messages -->
    @if (Model?.RecentMessages?.Count > 0)
    {
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header"><i class="fa fa-envelope-open-text me-2 text-info"></i>Son Mesajlar</div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var msg in Model.RecentMessages)
                        {
                            <a asp-area="Admin" asp-controller="Contact" asp-action="Detail" asp-route-id="@msg.Id"
                               class="list-group-item list-group-item-action px-3 py-2">
                                <div class="d-flex justify-content-between">
                                    <strong class="small @(msg.IsRead ? "" : "text-primary")">@msg.SenderName</strong>
                                    <small class="text-muted">@msg.CreatedAt.ToString("dd.MM HH:mm")</small>
                                </div>
                                <div class="small text-muted text-truncate">@msg.Subject</div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Recent Projects -->
    @if (Model?.RecentProjects?.Count > 0)
    {
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header"><i class="fa fa-diagram-project me-2 text-success"></i>Son Projeler</div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var proj in Model.RecentProjects)
                        {
                            <a asp-area="Admin" asp-controller="Project" asp-action="Edit" asp-route-id="@proj.Id"
                               class="list-group-item list-group-item-action px-3 py-2 d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(proj.CoverImageUrl))
                                {
                                    <img src="@proj.CoverImageUrl" class="rounded" width="36" height="36" style="object-fit:cover" />
                                }
                                else
                                {
                                    <div class="rounded bg-secondary d-flex align-items-center justify-content-center" style="width:36px;height:36px">
                                        <i class="fa fa-image text-white small"></i>
                                    </div>
                                }
                                <div>
                                    <div class="small fw-semibold">@proj.Title</div>
                                    <div class="small text-muted">@proj.CreatedAt.ToString("dd.MM.yyyy")</div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model?.Last30DaysVisitors?.Select(d => d.Date.ToString("dd MMM")) ?? []));
    const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model?.Last30DaysVisitors?.Select(d => d.Count) ?? []));

    new Chart(document.getElementById('visitorChart'), {
        type: 'line',
        data: {
            labels,
            datasets: [{
                label: 'Ziyaretçi',
                data,
                borderColor: '#b0876a',
                backgroundColor: 'rgba(176,135,106,.12)',
                fill: true,
                tension: 0.4,
                pointRadius: 3
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,.04)' } },
                x: { grid: { display: false } }
            }
        }
    });
</script>
}
