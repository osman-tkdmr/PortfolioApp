@model IList<PortfolioApp.DTO.DTOs.Site.SeoSettingsDto>
@{
    ViewData["Title"] = "SEO Ayarları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-bold"><i class="fa fa-search me-2 text-primary"></i>SEO Ayarları</h5>
</div>

<div class="row g-3">
    @foreach (var item in Model ?? [])
    {
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="fa fa-file me-2"></i>/@item.PageSlug</span>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                        <i class="fa fa-pen me-1"></i>Düzenle
                    </a>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <div class="small text-muted">Meta Başlık</div>
                            <div>@item.MetaTitle</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Meta Açıklama</div>
                            <div class="text-muted small">@item.MetaDescription</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
