@model PortfolioApp.DTO.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "Şifre Değiştir";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-bold"><i class="fa fa-key me-2 text-primary"></i>Şifre Değiştir</h5>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <form method="post" asp-action="ChangePassword">
            @Html.AntiForgeryToken()
            <div class="card">
                <div class="card-body row g-3">
                    <div class="col-12">
                        <label asp-for="CurrentPassword" class="form-label fw-semibold"></label>
                        <input asp-for="CurrentPassword" class="form-control" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                        <input asp-for="NewPassword" class="form-control" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="ConfirmNewPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmNewPassword" class="form-control" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-primary mt-3">
                <i class="fa fa-floppy-disk me-1"></i>Şifreyi Güncelle
            </button>
        </form>
    </div>
</div>
