@model IList<PortfolioApp.DTO.DTOs.Blog.BlogTagDto>
@{
    ViewData["Title"] = "Blog Etiketleri";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-bold"><i class="fa fa-tags me-2 text-primary"></i>Blog Etiketleri</h5>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa fa-arrow-left me-1"></i>Yazılara Dön</a>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="fa fa-plus me-1"></i>Yeni Etiket
        </button>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="tagsTable">
            <thead class="table-light">
                <tr>
                    <th>Etiket Adı</th>
                    <th>Slug</th>
                    <th width="100" class="text-center">Yazı Sayısı</th>
                    <th width="100" class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tag in Model)
                {
                    <tr>
                        <td class="align-middle">
                            <span class="badge bg-secondary fs-6">@tag.Name</span>
                        </td>
                        <td class="align-middle text-muted">@tag.Slug</td>
                        <td class="align-middle text-center">
                            <span class="badge bg-info">@tag.PostCount</span>
                        </td>
                        <td class="align-middle text-center">
                            <button class="btn btn-sm btn-outline-danger btn-delete" data-id="@tag.Id">
                                <i class="fa fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-action="CreateTag">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Yeni Etiket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Etiket Adı <span class="text-danger">*</span></label>
                        <input name="Name" class="form-control" required />
                    </div>
                    <div class="form-check">
                        <input name="IsActive" type="checkbox" class="form-check-input" checked value="true" />
                        <input name="IsActive" type="hidden" value="false" />
                        <label class="form-check-label">Aktif</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $('#tagsTable').DataTable({ language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/tr.json' }, pageLength: 25 });

        $(document).on('click', '.btn-delete', function () {
            var id = $(this).data('id');
            Swal.fire({ title: 'Etiketi sil?', icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#d33', cancelButtonText: 'Vazgeç', confirmButtonText: 'Sil!'
            }).then(r => {
                if (r.isConfirmed) $.post('@Url.Action("DeleteTag")/' + id, res => {
                    if (res.success) { toastr.success(res.message); setTimeout(() => location.reload(), 1200); }
                    else toastr.error(res.message);
                });
            });
        });
    </script>
}
