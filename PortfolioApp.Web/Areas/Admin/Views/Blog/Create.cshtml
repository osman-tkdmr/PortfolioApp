@model PortfolioApp.DTO.DTOs.Blog.BlogPostCreateDto
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Yeni Blog Yazısı";
    var categories = ViewBag.Categories as IList<PortfolioApp.DTO.DTOs.Blog.BlogCategoryDto> ?? [];
    var tags = ViewBag.Tags as IList<PortfolioApp.DTO.DTOs.Blog.BlogTagDto> ?? [];
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="fa fa-plus me-2"></i>Yeni Blog Yazısı</span>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="fa fa-arrow-left me-1"></i>Geri</a>
    </div>
    <div class="card-body">
        <form method="post" asp-action="Create" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label fw-semibold">Başlık <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" placeholder="Blog yazısı başlığı" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Özet</label>
                    <textarea asp-for="Summary" class="form-control" rows="2" placeholder="Kısa açıklama..."></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">İçerik <span class="text-danger">*</span></label>
                    <textarea id="content" asp-for="Content" class="form-control" rows="15"></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Kategori</label>
                    <select asp-for="BlogCategoryId" class="form-select">
                        <option value="">-- Kategori Seç --</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Kapak Görseli</label>
                    <input type="file" name="coverImage" class="form-control" accept="image/*" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Etiketler</label>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var tag in tags)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="TagIds" value="@tag.Id" id="tag_@tag.Id" />
                                <label class="form-check-label small" for="tag_@tag.Id">@tag.Name</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check form-switch">
                        <input asp-for="IsPublished" class="form-check-input" role="switch" />
                        <label asp-for="IsPublished" class="form-check-label">Hemen Yayınla</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check form-switch">
                        <input asp-for="IsFeatured" class="form-check-input" role="switch" />
                        <label asp-for="IsFeatured" class="form-check-label">Öne Çıkar</label>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fa fa-floppy-disk me-1"></i>Kaydet
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script src="https://cdn.tiny.cloud/1/@Configuration["TinyMCE:ApiKey"]/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>
<script>
    tinymce.init({
        selector: '#content',
        height: 500,
        plugins: 'lists link image code table',
        toolbar: 'undo redo | formatselect | bold italic | alignleft aligncenter alignright | bullist numlist | link image | code',
        language: 'tr_TR'
    });
</script>
}
