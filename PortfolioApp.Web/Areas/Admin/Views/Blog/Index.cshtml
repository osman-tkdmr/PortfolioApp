@model IList<PortfolioApp.DTO.DTOs.Blog.BlogPostDto>
@{
    ViewData["Title"] = "Blog Yazıları";
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="fa fa-newspaper me-2"></i>Blog Yazıları</span>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="fa fa-plus me-1"></i>Yeni Yazı
        </a>
    </div>
    <div class="card-body">
        <table class="table table-hover datatable">
            <thead class="table-light">
                <tr>
                    <th>Başlık</th>
                    <th>Kategori</th>
                    <th>Durum</th>
                    <th>Görüntülenme</th>
                    <th>Tarih</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var post in Model ?? [])
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                                {
                                    <img src="@post.CoverImageUrl" class="rounded" width="40" height="30" style="object-fit:cover" />
                                }
                                <div>
                                    <div class="fw-semibold small">@post.Title</div>
                                    @if (post.IsFeatured)
                                    {
                                        <span class="badge bg-warning text-dark" style="font-size:.65rem">Öne Çıkan</span>
                                    }
                                </div>
                            </div>
                        </td>
                        <td><span class="badge bg-secondary">@post.CategoryName</span></td>
                        <td>
                            @if (post.IsPublished)
                            {
                                <span class="badge bg-success">Yayında</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Taslak</span>
                            }
                        </td>
                        <td>@post.ViewCount</td>
                        <td><small class="text-muted">@post.CreatedAt.ToString("dd.MM.yyyy")</small></td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@post.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="fa fa-pen"></i>
                                </a>
                                @if (post.IsPublished)
                                {
                                    <button class="btn btn-outline-warning btn-sm" onclick="togglePublish(@post.Id, false)" title="Yayından Kaldır">
                                        <i class="fa fa-eye-slash"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-success btn-sm" onclick="togglePublish(@post.Id, true)" title="Yayınla">
                                        <i class="fa fa-eye"></i>
                                    </button>
                                }
                                <button class="btn btn-outline-danger btn-sm btn-delete"
                                        data-url="@Url.Action("Delete", new { id = post.Id })"
                                        data-name="@post.Title">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script>
    function togglePublish(id, publish) {
        const url = publish ? '@Url.Action("Publish")' : '@Url.Action("Unpublish")';
        $.post(url.replace('0', id) + '?id=' + id, {
            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
        }).done(() => location.reload());
    }
</script>
}
