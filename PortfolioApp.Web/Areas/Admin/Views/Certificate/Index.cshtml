@model IList<PortfolioApp.DTO.DTOs.Portfolio.CertificateDto>
@{
    ViewData["Title"] = "Sertifikalar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-bold"><i class="fa fa-certificate me-2 text-primary"></i>Sertifikalar</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fa fa-plus me-1"></i>Yeni Ekle</a>
</div>

<div class="row g-3">
    @foreach (var item in Model ?? [])
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex gap-3 align-items-start">
                        @if (!string.IsNullOrEmpty(item.BadgeImageUrl))
                        {
                            <img src="@item.BadgeImageUrl" width="56" height="56" class="rounded" style="object-fit:contain;flex-shrink:0" />
                        }
                        else
                        {
                            <div style="width:56px;height:56px;border-radius:8px;background:#f0f0f0;display:flex;align-items:center;justify-content:center;flex-shrink:0"><i class="fa fa-award text-muted fa-2x"></i></div>
                        }
                        <div>
                            <div class="fw-semibold">@item.Name</div>
                            <div class="small text-muted">@item.IssuingOrganization</div>
                            <div class="small text-muted">@item.IssuedDate.ToString("MMM yyyy")</div>
                        </div>
                    </div>
                </div>
                <div class="card-footer d-flex gap-2 bg-transparent">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary flex-grow-1"><i class="fa fa-pen me-1"></i>Düzenle</a>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteItem(@item.Id)"><i class="fa fa-trash"></i></button>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
function deleteItem(id) {
    Swal.fire({ title: 'Silmek istediğinize emin misiniz?', icon: 'warning', showCancelButton: true, confirmButtonText: 'Evet, Sil', cancelButtonText: 'İptal', confirmButtonColor: '#dc3545' }).then(r => {
        if (!r.isConfirmed) return;
        fetch(`/Admin/Certificate/Delete/${id}`, { method: 'POST', headers: { 'RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]').value } }).then(() => location.reload());
    });
}
</script>
}
