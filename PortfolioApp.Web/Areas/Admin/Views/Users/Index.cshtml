@model IList<PortfolioApp.DTO.ViewModels.Admin.UserListItemViewModel>
@{
    ViewData["Title"] = "Kullanıcılar";
}

@Html.AntiForgeryToken()

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-bold"><i class="fa fa-users me-2 text-primary"></i>Kullanıcılar</h5>
    <span class="text-secondary small">Toplam @Model.Count kullanıcı</span>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Ad Soyad</th>
                    <th>Kullanıcı Adı</th>
                    <th>E-posta</th>
                    <th>Roller</th>
                    <th>Kayıt Tarihi</th>
                    <th>Durum</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="fw-semibold">@user.FullName</td>
                        <td><a href="/u/@user.Handle" target="_blank">@@@user.Handle</a></td>
                        <td>
                            @user.Email
                            @if (!user.EmailConfirmed)
                            {
                                <span class="badge bg-warning text-dark ms-1">Doğrulanmadı</span>
                            }
                        </td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                <span class="badge bg-secondary me-1">@role</span>
                            }
                        </td>
                        <td>@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td><span class="badge @(user.IsActive ? "bg-success" : "bg-danger")">@(user.IsActive ? "Aktif" : "Pasif")</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-secondary btn-toggle-active" data-id="@user.Id">
                                @(user.IsActive ? "Devre Dışı Bırak" : "Aktif Et")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    $(document).on('click', '.btn-toggle-active', function () {
        const id = $(this).data('id');
        $.post(`/Admin/Users/ToggleActive/${id}`, { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() })
            .done(res => { toastr.success(res.message); setTimeout(() => location.reload(), 800); })
            .fail(() => toastr.error('Bir hata oluştu.'));
    });
</script>
}
