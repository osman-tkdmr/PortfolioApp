@model IList<PortfolioApp.DTO.DTOs.Project.ProjectDto>
@{
    ViewData["Title"] = "Projeler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-bold"><i class="fa fa-diagram-project me-2 text-primary"></i>Projeler</h5>
    <div class="d-flex gap-2">
        <a asp-action="Categories" class="btn btn-outline-secondary btn-sm">
            <i class="fa fa-folder me-1"></i>Kategoriler
        </a>
        <a asp-action="Technologies" class="btn btn-outline-secondary btn-sm">
            <i class="fa fa-microchip me-1"></i>Teknolojiler
        </a>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="fa fa-plus me-1"></i>Yeni Proje
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="projectsTable">
            <thead class="table-light">
                <tr>
                    <th width="60">Görsel</th>
                    <th>Başlık</th>
                    <th>Kategori</th>
                    <th>Teknolojiler</th>
                    <th width="80" class="text-center">Öne Çıkan</th>
                    <th width="80" class="text-center">Durum</th>
                    <th width="130" class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in (Model ?? []).OrderBy(p => p.DisplayOrder).ThenByDescending(p => p.CreatedAt))
                {
                    <tr>
                        <td class="align-middle">
                            @if (!string.IsNullOrEmpty(item.CoverImageUrl))
                            {
                                <img src="@item.CoverImageUrl" alt="@item.Title"
                                     class="rounded" style="width:48px;height:36px;object-fit:cover;" />
                            }
                            else
                            {
                                <div class="rounded bg-light d-flex align-items-center justify-content-center"
                                     style="width:48px;height:36px;">
                                    <i class="fa fa-image text-muted"></i>
                                </div>
                            }
                        </td>
                        <td class="align-middle">
                            <div class="fw-semibold">@item.Title</div>
                            @if (!string.IsNullOrEmpty(item.ShortDescription))
                            {
                                <small class="text-muted">@(item.ShortDescription.Length > 60 ? item.ShortDescription[..60] + "…" : item.ShortDescription)</small>
                            }
                            <div class="mt-1">
                                @if (!string.IsNullOrEmpty(item.DemoUrl))
                                {
                                    <a href="@item.DemoUrl" target="_blank" class="badge bg-info text-decoration-none me-1" title="Demo">
                                        <i class="fa fa-eye me-1"></i>Demo
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(item.SourceUrl))
                                {
                                    <a href="@item.SourceUrl" target="_blank" class="badge bg-dark text-decoration-none" title="Kaynak Kod">
                                        <i class="fa-brands fa-github me-1"></i>Kaynak
                                    </a>
                                }
                            </div>
                        </td>
                        <td class="align-middle">
                            <span class="badge bg-secondary">@item.CategoryName</span>
                        </td>
                        <td class="align-middle">
                            @if (item.Technologies.Any())
                            {
                                @foreach (var tech in item.Technologies.Take(4))
                                {
                                    <span class="badge bg-light text-dark border me-1 mb-1">@tech.Name</span>
                                }
                                @if (item.Technologies.Count > 4)
                                {
                                    <span class="badge bg-light text-muted border">+@(item.Technologies.Count - 4)</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="align-middle text-center">
                            <button class="btn btn-sm @(item.IsFeatured ? "btn-warning" : "btn-outline-secondary") toggle-featured"
                                    data-id="@item.Id" title="@(item.IsFeatured ? "Öne çıkarıldı" : "Öne çıkar")">
                                <i class="fa fa-star"></i>
                            </button>
                        </td>
                        <td class="align-middle text-center">
                            <span class="badge @(item.IsActive ? "bg-success" : "bg-danger")">
                                @(item.IsActive ? "Aktif" : "Pasif")
                            </span>
                        </td>
                        <td class="align-middle text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Düzenle">
                                <i class="fa fa-pen"></i>
                            </a>
                            <button class="btn btn-sm btn-outline-danger btn-delete" data-id="@item.Id" title="Sil">
                                <i class="fa fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // DataTable
        $('#projectsTable').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/tr.json',
                emptyTable: 'Henüz proje eklenmemiş.'
            },
            columnDefs: [{ orderable: false, targets: [0, 4, 5, 6] }],
            pageLength: 20
        });

        // Toggle Featured
        $(document).on('click', '.toggle-featured', function () {
            var btn = $(this);
            var id = btn.data('id');
            $.post('@Url.Action("ToggleFeatured")', { id: id }, function (res) {
                if (res.success) {
                    btn.toggleClass('btn-warning btn-outline-secondary');
                    toastr.success(res.message);
                } else {
                    toastr.error(res.message);
                }
            });
        });

        // Delete
        $(document).on('click', '.btn-delete', function () {
            var id = $(this).data('id');
            Swal.fire({
                title: 'Projeyi sil?',
                text: 'Bu işlem geri alınamaz.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonText: 'Vazgeç',
                confirmButtonText: 'Evet, Sil!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("Delete")', { id: id }, function (res) {
                        if (res.success) {
                            toastr.success(res.message);
                            setTimeout(() => location.reload(), 1200);
                        } else {
                            toastr.error(res.message);
                        }
                    });
                }
            });
        });
    </script>
}
