@model IList<PortfolioApp.DTO.DTOs.Project.ProjectCategoryDto>
@{
    ViewData["Title"] = "Proje Kategorileri";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-bold"><i class="fa fa-folder me-2 text-primary"></i>Proje Kategorileri</h5>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa fa-arrow-left me-1"></i>Projelere Dön</a>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="fa fa-plus me-1"></i>Yeni Kategori
        </button>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="categoriesTable">
            <thead class="table-light">
                <tr>
                    <th>Kategori Adı</th>
                    <th>Açıklama</th>
                    <th width="100" class="text-center">Proje Sayısı</th>
                    <th width="80" class="text-center">Durum</th>
                    <th width="100" class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model.OrderBy(c => c.DisplayOrder))
                {
                    <tr>
                        <td class="align-middle fw-semibold">
                            @if (!string.IsNullOrEmpty(cat.IconClass))
                            {
                                <i class="@cat.IconClass me-2 text-primary"></i>
                            }
                            @cat.Name
                        </td>
                        <td class="align-middle text-muted">@cat.Description</td>
                        <td class="align-middle text-center">
                            <span class="badge bg-secondary">@cat.ProjectCount</span>
                        </td>
                        <td class="align-middle text-center">
                            <span class="badge @(cat.IsActive ? "bg-success" : "bg-danger")">
                                @(cat.IsActive ? "Aktif" : "Pasif")
                            </span>
                        </td>
                        <td class="align-middle text-center">
                            <button class="btn btn-sm btn-outline-primary me-1 btn-edit"
                                    data-id="@cat.Id" data-name="@cat.Name" data-description="@cat.Description"
                                    data-icon="@cat.IconClass" data-order="@cat.DisplayOrder" data-active="@cat.IsActive.ToString().ToLower()"
                                    title="Düzenle">
                                <i class="fa fa-pen"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger btn-delete" data-id="@cat.Id" title="Sil">
                                <i class="fa fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-action="CreateCategory">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Yeni Kategori</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Kategori Adı <span class="text-danger">*</span></label>
                        <input name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Açıklama</label>
                        <textarea name="Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">İkon Sınıfı</label>
                        <input name="IconClass" class="form-control" placeholder="fa fa-code" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Sıra</label>
                        <input name="DisplayOrder" type="number" class="form-control" value="0" />
                    </div>
                    <div class="form-check">
                        <input name="IsActive" type="checkbox" class="form-check-input" checked value="true" />
                        <input name="IsActive" type="hidden" value="false" />
                        <label class="form-check-label">Aktif</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" id="editForm">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editId" name="Id" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Kategori Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Kategori Adı <span class="text-danger">*</span></label>
                        <input id="editName" name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Açıklama</label>
                        <textarea id="editDescription" name="Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">İkon Sınıfı</label>
                        <input id="editIcon" name="IconClass" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Sıra</label>
                        <input id="editOrder" name="DisplayOrder" type="number" class="form-control" />
                    </div>
                    <div class="form-check">
                        <input id="editActive" name="IsActive" type="checkbox" class="form-check-input" value="true" />
                        <input name="IsActive" type="hidden" value="false" />
                        <label class="form-check-label">Aktif</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $('#categoriesTable').DataTable({ language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/tr.json' }, pageLength: 25 });

        $(document).on('click', '.btn-edit', function () {
            var id = $(this).data('id');
            $('#editId').val(id);
            $('#editName').val($(this).data('name'));
            $('#editDescription').val($(this).data('description'));
            $('#editIcon').val($(this).data('icon'));
            $('#editOrder').val($(this).data('order'));
            $('#editActive').prop('checked', $(this).data('active') === true || $(this).data('active') === 'true');
            $('#editForm').attr('action', '@Url.Action("UpdateCategory")/' + id);
            $('#editModal').modal('show');
        });

        $(document).on('click', '.btn-delete', function () {
            var id = $(this).data('id');
            Swal.fire({
                title: 'Kategoriyi sil?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonText: 'Vazgeç',
                confirmButtonText: 'Sil!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("DeleteCategory")/' + id, function (res) {
                        if (res.success) { toastr.success(res.message); setTimeout(() => location.reload(), 1200); }
                        else toastr.error(res.message);
                    });
                }
            });
        });
    </script>
}
