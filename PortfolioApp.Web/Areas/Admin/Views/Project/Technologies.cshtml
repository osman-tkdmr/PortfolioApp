@model IList<PortfolioApp.DTO.DTOs.Project.TechnologyDto>
@{
    ViewData["Title"] = "Teknolojiler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-bold"><i class="fa fa-microchip me-2 text-primary"></i>Teknolojiler</h5>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa fa-arrow-left me-1"></i>Projelere Dön</a>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="fa fa-plus me-1"></i>Yeni Teknoloji
        </button>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="techTable">
            <thead class="table-light">
                <tr>
                    <th>Teknoloji</th>
                    <th>İkon / Renk</th>
                    <th width="80" class="text-center">Sıra</th>
                    <th width="80" class="text-center">Durum</th>
                    <th width="100" class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tech in Model.OrderBy(t => t.DisplayOrder))
                {
                    <tr>
                        <td class="align-middle fw-semibold">
                            @if (!string.IsNullOrEmpty(tech.IconClass))
                            {
                                <i class="@tech.IconClass me-2" style="color: @(tech.Color ?? "inherit")"></i>
                            }
                            @tech.Name
                        </td>
                        <td class="align-middle">
                            @if (!string.IsNullOrEmpty(tech.Color))
                            {
                                <span class="badge" style="background-color:@tech.Color">@tech.Color</span>
                            }
                        </td>
                        <td class="align-middle text-center">@tech.DisplayOrder</td>
                        <td class="align-middle text-center">
                            <span class="badge @(tech.IsActive ? "bg-success" : "bg-danger")">
                                @(tech.IsActive ? "Aktif" : "Pasif")
                            </span>
                        </td>
                        <td class="align-middle text-center">
                            <button class="btn btn-sm btn-outline-primary me-1 btn-edit"
                                    data-id="@tech.Id" data-name="@tech.Name" data-icon="@tech.IconClass"
                                    data-color="@tech.Color" data-order="@tech.DisplayOrder" data-active="@tech.IsActive.ToString().ToLower()"
                                    title="Düzenle">
                                <i class="fa fa-pen"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger btn-delete" data-id="@tech.Id" title="Sil">
                                <i class="fa fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-action="CreateTechnology">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Yeni Teknoloji</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Teknoloji Adı <span class="text-danger">*</span></label>
                        <input name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">İkon Sınıfı</label>
                        <input name="IconClass" class="form-control" placeholder="fa-brands fa-js" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Renk</label>
                        <input name="Color" type="color" class="form-control form-control-color" value="#007bff" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Sıra</label>
                        <input name="DisplayOrder" type="number" class="form-control" value="0" />
                    </div>
                    <div class="form-check">
                        <input name="IsActive" type="checkbox" class="form-check-input" checked value="true" />
                        <input name="IsActive" type="hidden" value="false" />
                        <label class="form-check-label">Aktif</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" id="editForm">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editId" name="Id" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Teknoloji Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Teknoloji Adı <span class="text-danger">*</span></label>
                        <input id="editName" name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">İkon Sınıfı</label>
                        <input id="editIcon" name="IconClass" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Renk</label>
                        <input id="editColor" name="Color" type="color" class="form-control form-control-color" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Sıra</label>
                        <input id="editOrder" name="DisplayOrder" type="number" class="form-control" />
                    </div>
                    <div class="form-check">
                        <input id="editActive" name="IsActive" type="checkbox" class="form-check-input" value="true" />
                        <input name="IsActive" type="hidden" value="false" />
                        <label class="form-check-label">Aktif</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $('#techTable').DataTable({ language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/tr.json' }, pageLength: 25 });

        $(document).on('click', '.btn-edit', function () {
            var id = $(this).data('id');
            $('#editId').val(id);
            $('#editName').val($(this).data('name'));
            $('#editIcon').val($(this).data('icon'));
            $('#editColor').val($(this).data('color') || '#007bff');
            $('#editOrder').val($(this).data('order'));
            $('#editActive').prop('checked', $(this).data('active') === true || $(this).data('active') === 'true');
            $('#editForm').attr('action', '@Url.Action("UpdateTechnology")/' + id);
            $('#editModal').modal('show');
        });

        $(document).on('click', '.btn-delete', function () {
            var id = $(this).data('id');
            Swal.fire({
                title: 'Teknolojiyi sil?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonText: 'Vazgeç',
                confirmButtonText: 'Sil!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("DeleteTechnology")/' + id, function (res) {
                        if (res.success) { toastr.success(res.message); setTimeout(() => location.reload(), 1200); }
                        else toastr.error(res.message);
                    });
                }
            });
        });
    </script>
}
