@model PortfolioApp.DTO.ViewModels.Public.BlogListViewModel
@{
    // Only the Modern theme has a working inner-page layout so far
    Layout = "~/Views/Themes/Modern/_InnerLayout.cshtml";
    ViewData["Title"] = "Blog";
    ViewData["MetaTitle"] = Model.Seo?.MetaTitle ?? "Blog";
    ViewData["MetaDescription"] = Model.Seo?.MetaDescription;
    ViewData["ActiveThemeCss"] = Model.ActiveThemeCss;
}

<section class="section">
    <div class="container">
        <div class="text-center mb-5 fade-up">
            <p class="section-subtitle">Blog</p>
            <h2 class="section-title">@Localizer["PageTitle"]</h2>
            <div class="section-divider mx-auto"></div>
        </div>

        <div class="row g-4">
            <!-- Sidebar filters -->
            <div class="col-lg-3">
                <form method="get" class="mb-4">
                    @if (!string.IsNullOrEmpty(Model.CurrentCategory))
                    {
                        <input type="hidden" name="category" value="@Model.CurrentCategory" />
                    }
                    <div class="input-group">
                        <input type="text" name="q" value="@Model.SearchQuery" class="form-control form-control-modern" placeholder="@Localizer["SearchPlaceholder"]" />
                        <button type="submit" class="btn-primary-modern" style="border-radius:0 100px 100px 0"><i class="fa fa-search"></i></button>
                    </div>
                </form>

                @if (Model.Categories.Count > 0)
                {
                    <h6 class="fw-bold mb-3">@Localizer["CategoriesHeading"]</h6>
                    <div class="d-flex flex-column gap-2 mb-4">
                        <a href="/blog" class="text-decoration-none @(string.IsNullOrEmpty(Model.CurrentCategory) ? "fw-bold" : "")"
                           style="color:@(string.IsNullOrEmpty(Model.CurrentCategory) ? "var(--primary)" : "var(--text-secondary)")">
                            @Localizer["AllCategoriesLink"]
                        </a>
                        @foreach (var cat in Model.Categories)
                        {
                            <a href="/blog?category=@cat.Slug" class="text-decoration-none @(Model.CurrentCategory == cat.Slug ? "fw-bold" : "")"
                               style="color:@(Model.CurrentCategory == cat.Slug ? "var(--primary)" : "var(--text-secondary)")">
                                @cat.Name <span class="text-muted small">(@cat.PostCount)</span>
                            </a>
                        }
                    </div>
                }
            </div>

            <!-- Post list -->
            <div class="col-lg-9">
                @if (Model.Posts.Items.Count == 0)
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fa fa-newspaper fa-3x opacity-25 mb-3"></i>
                        <p>@Localizer["NoPostsMessage"]</p>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var post in Model.Posts.Items)
                        {
                            <div class="col-md-6 fade-up">
                                <a href="/blog/@post.Slug" class="text-decoration-none">
                                    <div class="blog-card card-modern h-100">
                                        @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                                        {
                                            <img src="@post.CoverImageUrl" alt="@post.Title" class="w-100" style="height:200px;object-fit:cover" />
                                        }
                                        else
                                        {
                                            <div style="height:200px;background:linear-gradient(135deg,var(--bg-section),rgba(176,135,106,.15));display:flex;align-items:center;justify-content:center">
                                                <i class="fa fa-newspaper fa-3x opacity-25"></i>
                                            </div>
                                        }
                                        <div class="p-4">
                                            @if (!string.IsNullOrEmpty(post.CategoryName))
                                            {
                                                <span class="badge rounded-pill mb-2" style="background:rgba(176,135,106,.1);color:var(--primary)">@post.CategoryName</span>
                                            }
                                            <h6 class="fw-bold text-dark mb-2">@post.Title</h6>
                                            @if (!string.IsNullOrEmpty(post.Summary))
                                            {
                                                <p class="text-muted small mb-3" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">@post.Summary</p>
                                            }
                                            <div class="d-flex align-items-center gap-3 text-muted" style="font-size:.8rem">
                                                @if (post.PublishedAt.HasValue)
                                                {
                                                    <span><i class="fa fa-calendar fa-xs me-1"></i>@post.PublishedAt.Value.ToString("dd MMM yyyy")</span>
                                                }
                                                <span><i class="fa fa-clock fa-xs me-1"></i>@post.ReadTimeMinutes @Localizer["ReadTimeSuffix"]</span>
                                                <span><i class="fa fa-eye fa-xs me-1"></i>@post.ViewCount</span>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>

                    @if (Model.Posts.TotalPages > 1)
                    {
                        <nav class="mt-5">
                            <ul class="pagination justify-content-center">
                                @for (var p = 1; p <= Model.Posts.TotalPages; p++)
                                {
                                    <li class="page-item @(p == Model.Posts.PageNumber ? "active" : "")">
                                        <a class="page-link" style="@(p == Model.Posts.PageNumber ? "background:var(--primary);border-color:var(--primary)" : "color:var(--primary)")"
                                           href="/blog?page=@p@(string.IsNullOrEmpty(Model.CurrentCategory) ? "" : $"&category={Model.CurrentCategory}")@(string.IsNullOrEmpty(Model.SearchQuery) ? "" : $"&q={Model.SearchQuery}")">
                                            @p
                                        </a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</section>
