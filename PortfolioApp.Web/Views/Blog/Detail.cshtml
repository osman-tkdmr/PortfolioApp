@model PortfolioApp.DTO.ViewModels.Public.BlogDetailViewModel
@{
    Layout = "~/Views/Themes/Modern/_InnerLayout.cshtml";
    ViewData["Title"] = Model.Post.Title;
    ViewData["MetaTitle"] = Model.Seo?.MetaTitle ?? Model.Post.Title;
    ViewData["MetaDescription"] = Model.Seo?.MetaDescription ?? Model.Post.Summary;
    ViewData["ActiveThemeCss"] = Model.ActiveThemeCss;
}

<section class="section">
    <div class="container" style="max-width:800px">
        <a href="/blog" class="text-decoration-none small" style="color:var(--text-muted)"><i class="fa fa-arrow-left me-1"></i>@Localizer["BackToAllPosts"]</a>

        <div class="mt-3 mb-4 fade-up">
            @if (!string.IsNullOrEmpty(Model.Post.CategoryName))
            {
                <span class="badge rounded-pill mb-2" style="background:rgba(176,135,106,.1);color:var(--primary)">@Model.Post.CategoryName</span>
            }
            <h1 class="mt-2" style="font-family:var(--font-heading);font-size:clamp(1.8rem,4vw,2.6rem)">@Model.Post.Title</h1>
            <div class="d-flex align-items-center gap-3 text-muted mt-3" style="font-size:.9rem">
                <span><i class="fa fa-user fa-xs me-1"></i>@Model.Post.AuthorName</span>
                @if (Model.Post.PublishedAt.HasValue)
                {
                    <span><i class="fa fa-calendar fa-xs me-1"></i>@Model.Post.PublishedAt.Value.ToString("dd MMMM yyyy")</span>
                }
                <span><i class="fa fa-clock fa-xs me-1"></i>@Model.Post.ReadTimeMinutes @Localizer["ReadTimeSuffix"]</span>
                <span><i class="fa fa-eye fa-xs me-1"></i>@Model.Post.ViewCount @Localizer["ViewsSuffix"]</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Post.CoverImageUrl))
        {
            <img src="@Model.Post.CoverImageUrl" alt="@Model.Post.Title" class="w-100 mb-4 fade-up" style="border-radius:var(--radius);max-height:420px;object-fit:cover" />
        }

        <div class="fade-up" style="line-height:1.9">
            @Html.Raw(Model.Post.Content)
        </div>

        @if (Model.Post.TagNames.Count > 0)
        {
            <div class="d-flex flex-wrap gap-2 mt-5 pt-4" style="border-top:1px solid var(--border)">
                @foreach (var tag in Model.Post.TagNames)
                {
                    <span class="badge rounded-pill" style="background:var(--bg-section);color:var(--text-secondary)">#@tag</span>
                }
            </div>
        }

        @if (Model.RelatedPosts.Count > 0)
        {
            <div class="mt-5 pt-4" style="border-top:1px solid var(--border)">
                <h5 class="fw-bold mb-4">@Localizer["RelatedPostsHeading"]</h5>
                <div class="row g-4">
                    @foreach (var related in Model.RelatedPosts)
                    {
                        <div class="col-md-6">
                            <a href="/blog/@related.Slug" class="text-decoration-none">
                                <div class="blog-card card-modern h-100 p-3">
                                    <h6 class="fw-bold text-dark mb-0">@related.Title</h6>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>
