@{
    var isTurkish = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "tr";
    var targetCulture = isTurkish ? "en-US" : "tr-TR";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}
<form asp-controller="Home" asp-action="SetLanguage" method="post" class="lang-toggle-form">
    <input type="hidden" name="culture" value="@targetCulture" />
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    <button type="submit" class="lang-toggle-track" data-active="@(isTurkish ? "tr" : "en")"
            title="@SharedLocalizer["LanguageSwitchTitle"]" aria-label="@SharedLocalizer["LanguageSwitchTitle"]">
        <span class="lang-toggle-thumb"></span>
        <span class="lang-toggle-option@(isTurkish ? " active" : "")">TR</span>
        <span class="lang-toggle-option@(isTurkish ? "" : " active")">EN</span>
    </button>
</form>

<style>
    .lang-toggle-form {
        display: inline-block;
    }

    .lang-toggle-track {
        position: relative;
        display: inline-grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        width: 74px;
        height: 30px;
        padding: 3px;
        border: 1px solid var(--border, rgba(127, 127, 127, .3));
        border-radius: 999px;
        background: rgba(127, 127, 127, .16);
        cursor: pointer;
        overflow: hidden;
        transition: border-color .2s ease;
    }

    .lang-toggle-track:hover {
        border-color: var(--primary, #7c6af7);
    }

    .lang-toggle-track:focus-visible {
        outline: 2px solid var(--primary, #7c6af7);
        outline-offset: 2px;
    }

    .lang-toggle-thumb {
        position: absolute;
        z-index: 0;
        top: 3px;
        left: 3px;
        width: calc(50% - 4px);
        height: calc(100% - 6px);
        border-radius: 999px;
        background: var(--primary, #7c6af7);
        box-shadow: 0 2px 6px rgba(0, 0, 0, .25);
        transition: transform .25s ease, background-color .2s ease;
    }

    .lang-toggle-track:hover .lang-toggle-thumb {
        background: var(--primary-hover, var(--primary, #7c6af7));
    }

    .lang-toggle-track[data-active="en"] .lang-toggle-thumb {
        transform: translateX(calc(100% + 2px));
    }

    .lang-toggle-option {
        position: relative;
        z-index: 1;
        text-align: center;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .02em;
        color: var(--text-muted, rgba(127, 127, 127, .8));
        pointer-events: none;
        transition: color .25s ease;
    }

    .lang-toggle-option.active {
        color: #fff;
    }
</style>
