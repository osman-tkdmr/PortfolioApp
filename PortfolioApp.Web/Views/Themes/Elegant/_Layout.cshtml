@model PortfolioApp.DTO.ViewModels.Public.HomeViewModel
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(Model?.Seo?.MetaTitle ?? Model?.SiteSettings?.SiteName ?? "Portfolio")</title>
    <meta name="description" content="@Model?.Seo?.MetaDescription" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="/css/themes/modern.css" />
    <link rel="stylesheet" href="/css/themes/elegant.css" />
    @await Html.PartialAsync("_GoogleAnalytics", Model?.SiteSettings?.GoogleAnalyticsId)
</head>
<body>
<nav class="navbar" id="mainNav">
    <div class="container header-inner">
        <div class="logo-container">
            <a class="navbar-brand" href="#">@(Model?.SiteSettings?.SiteName ?? "Portfolio")<span>.</span></a>
        </div>
        <div class="nav-container">
            <ul class="navbar-nav gap-1">
                <li class="nav-item"><a class="nav-link active" href="#hero">@SharedLocalizer["NavHome"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#about">@SharedLocalizer["NavAbout"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#skills">@SharedLocalizer["NavSkills"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#portfolio">@SharedLocalizer["NavPortfolio"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#resume">@SharedLocalizer["NavResume"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#blog">@SharedLocalizer["NavBlog"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#contact">@SharedLocalizer["NavContact"]</a></li>
            </ul>
        </div>
        <div class="language-container">
            @await Html.PartialAsync("_LanguageToggle")
        </div>
    </div>
</nav>

@await Html.PartialAsync("~/Views/Themes/Elegant/Sections/Hero.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Elegant/Sections/About.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Elegant/Sections/Skills.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Elegant/Sections/Portfolio.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Elegant/Sections/Resume.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Elegant/Sections/Testimonials.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Elegant/Sections/Blog.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Elegant/Sections/Contact.cshtml", Model)

<footer class="footer">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 mb-3 mb-md-0">
                <div class="fw-bold text-white" style="font-family:var(--font-heading)">@(Model?.SiteSettings?.SiteName ?? "Portfolio")<span style="color:var(--primary)">.</span></div>
                <div class="small">© @DateTime.Now.Year. @SharedLocalizer["FooterRights"]</div>
            </div>
            <div class="col-md-6 text-md-end">
                @foreach (var social in Model?.SocialMediaLinks ?? [])
                {
                    <a href="@social.Url" target="_blank" rel="noopener" class="me-3 fs-5"><i class="@social.IconClass"></i></a>
                }
            </div>
        </div>
    </div>
</footer>

<button id="backToTop" onclick="window.scrollTo({top:0,behavior:'smooth'})"
    style="position:fixed;bottom:2rem;right:2rem;width:44px;height:44px;border-radius:50%;background:var(--primary);color:#fff;border:none;cursor:pointer;display:none;align-items:center;justify-content:center;z-index:99;box-shadow:0 4px 16px rgba(0,0,0,.3)">
    <i class="fa fa-chevron-up fa-sm"></i>
</button>

<!-- Bottom Navigation (mobile only, desktop navbar untouched) -->
<nav class="bottom-nav">
    <a href="#hero" class="bottom-nav-item active"><i class="fa fa-house"></i><span>@SharedLocalizer["NavHome"]</span></a>
    <a href="#about" class="bottom-nav-item"><i class="fa fa-user"></i><span>@SharedLocalizer["NavAbout"]</span></a>
    <a href="#portfolio" class="bottom-nav-item"><i class="fa fa-diagram-project"></i><span>@SharedLocalizer["NavPortfolio"]</span></a>
    <a href="#blog" class="bottom-nav-item"><i class="fa fa-newspaper"></i><span>@SharedLocalizer["NavBlog"]</span></a>
    <a href="#contact" class="bottom-nav-item"><i class="fa fa-envelope"></i><span>@SharedLocalizer["NavContact"]</span></a>
</nav>

@RenderBody()

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    window.addEventListener('scroll', () => {
        const btn = document.getElementById('backToTop');
        const nav = document.getElementById('mainNav');
        if (window.scrollY > 50) { nav?.classList.add('scrolled'); btn.style.display = 'flex'; }
        else { nav?.classList.remove('scrolled'); btn.style.display = 'none'; }
    });
    const observer = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: .15 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    const skillObserver = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) e.target.querySelectorAll('.skill-fill').forEach(b => { b.style.width = b.dataset.width + '%'; }); });
    }, { threshold: .3 });
    document.querySelectorAll('.skills-section').forEach(el => skillObserver.observe(el));

    // Active nav link on scroll (desktop navbar + mobile bottom nav)
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-link, .bottom-nav-item');
    window.addEventListener('scroll', () => {
        let current = '';
        sections.forEach(s => { if (window.scrollY >= s.offsetTop - 100) current = s.id; });
        navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === '#' + current) link.classList.add('active');
        });
    });
</script>
</body>
</html>
