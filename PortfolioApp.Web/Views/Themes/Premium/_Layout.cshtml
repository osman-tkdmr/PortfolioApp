@model PortfolioApp.DTO.ViewModels.Public.HomeViewModel
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(Model?.Seo?.MetaTitle ?? Model?.SiteSettings?.SiteName ?? "Portfolio")</title>
    <meta name="description" content="@Model?.Seo?.MetaDescription" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="/css/themes/modern.css" />
    <link rel="stylesheet" href="/css/themes/premium.css" />
</head>
<body>
<nav class="navbar navbar-expand-lg" id="mainNav">
    <div class="container">
        <a class="navbar-brand" href="#">@(Model?.SiteSettings?.SiteName ?? "Portfolio")<span>.</span></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto gap-1">
                <li class="nav-item"><a class="nav-link active" href="#hero">@SharedLocalizer["NavHome"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#about">@SharedLocalizer["NavAbout"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#skills">@SharedLocalizer["NavSkills"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#portfolio">@SharedLocalizer["NavPortfolio"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#resume">@SharedLocalizer["NavResume"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#blog">@SharedLocalizer["NavBlog"]</a></li>
                <li class="nav-item"><a class="nav-link" href="#contact">@SharedLocalizer["NavContact"]</a></li>
            </ul>
        </div>
    </div>
</nav>

@await Html.PartialAsync("~/Views/Themes/Premium/Sections/Hero.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Premium/Sections/About.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Premium/Sections/Skills.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Premium/Sections/Portfolio.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Premium/Sections/Resume.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Premium/Sections/Testimonials.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Premium/Sections/Blog.cshtml", Model)
@await Html.PartialAsync("~/Views/Themes/Premium/Sections/Contact.cshtml", Model)

<footer class="footer">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 mb-3 mb-md-0">
                <div class="fw-bold text-white" style="font-family:var(--font-heading)">@(Model?.SiteSettings?.SiteName ?? "Portfolio")<span style="color:var(--primary)">.</span></div>
                <div class="small">© @DateTime.Now.Year. @SharedLocalizer["FooterRights"]</div>
            </div>
            <div class="col-md-6 text-md-end">
                @foreach (var social in Model?.SocialMediaLinks ?? [])
                {
                    <a href="@social.Url" target="_blank" rel="noopener" class="me-3 fs-5"><i class="@social.IconClass"></i></a>
                }
            </div>
        </div>
    </div>
</footer>

<button id="backToTop" onclick="window.scrollTo({top:0,behavior:'smooth'})"
    style="position:fixed;bottom:2rem;right:2rem;width:44px;height:44px;border-radius:50%;background:var(--primary);color:#fff;border:none;cursor:pointer;display:none;align-items:center;justify-content:center;z-index:99;box-shadow:0 4px 16px rgba(0,0,0,.3)">
    <i class="fa fa-chevron-up fa-sm"></i>
</button>

@RenderBody()

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    window.addEventListener('scroll', () => {
        const btn = document.getElementById('backToTop');
        const nav = document.getElementById('mainNav');
        if (window.scrollY > 50) { nav?.classList.add('scrolled'); btn.style.display = 'flex'; }
        else { nav?.classList.remove('scrolled'); btn.style.display = 'none'; }
    });
    const observer = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: .15 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    const skillObserver = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) e.target.querySelectorAll('.skill-fill').forEach(b => { b.style.width = b.dataset.width + '%'; }); });
    }, { threshold: .3 });
    document.querySelectorAll('.skills-section').forEach(el => skillObserver.observe(el));
</script>
</body>
</html>
