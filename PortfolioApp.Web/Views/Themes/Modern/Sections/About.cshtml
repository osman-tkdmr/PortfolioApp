@model PortfolioApp.DTO.ViewModels.Public.HomeViewModel
<section id="about" class="section section-alt">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5 text-center fade-up">
                @if (!string.IsNullOrEmpty(Model?.About?.ProfileImageUrl))
                {
                    <img src="@Model.About.ProfileImageUrl" alt="About"
                         class="img-fluid rounded-4 shadow" style="max-height:450px;object-fit:cover" />
                }
            </div>
            <div class="col-lg-7 fade-up" style="transition-delay:.15s">
                <p class="section-subtitle">@Localizer["SectionLabel"]</p>
                <h2 class="section-title">@(Model?.About?.Title ?? Localizer["DefaultTitle"].Value)</h2>
                <div class="section-divider"></div>
                <p class="text-secondary lh-lg mb-4">@Model?.About?.Subtitle</p>
                @if (!string.IsNullOrEmpty(Model?.About?.Content))
                {
                    <div class="text-secondary lh-lg mb-4">@Html.Raw(Model.About.Content)</div>
                }
                <div class="row g-3 mb-4">
                    @if (Model?.Achievements?.Count > 0)
                    {
                        @foreach (var ach in Model.Achievements.Take(3))
                        {
                            <div class="col-4 text-center">
                                <div class="fw-bold" style="font-size:1.5rem;color:var(--primary)">@ach.Title</div>
                                <div class="small text-muted">@ach.Description</div>
                            </div>
                        }
                    }
                </div>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#contact" class="btn-primary-modern text-decoration-none">
                        <i class="fa fa-paper-plane"></i> @SharedLocalizer["CtaGetInTouch"]
                    </a>
                    @if (!string.IsNullOrEmpty(Model?.About?.CvFileUrl))
                    {
                        <a href="@Model.About.CvFileUrl" download class="btn-outline-modern text-decoration-none">
                            <i class="fa fa-download"></i> @SharedLocalizer["CtaDownloadCv"]
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
