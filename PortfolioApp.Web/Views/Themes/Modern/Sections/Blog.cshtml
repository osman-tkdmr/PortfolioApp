@model PortfolioApp.DTO.ViewModels.Public.HomeViewModel
@if (Model?.RecentPosts?.Count > 0)
{
    <section id="blog" class="section">
        <div class="container">
            <div class="text-center mb-5 fade-up">
                <p class="section-subtitle">Blog</p>
                <h2 class="section-title">@Localizer["SectionTitle"]</h2>
                <div class="section-divider mx-auto"></div>
            </div>
            <div class="row g-4">
                @foreach (var post in Model.RecentPosts)
                {
                    <div class="col-md-6 col-lg-4 fade-up">
                        <a href="/blog/@post.Slug" class="text-decoration-none">
                            <div class="blog-card card-modern h-100">
                                @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                                {
                                    <img src="@post.CoverImageUrl" alt="@post.Title" class="w-100" style="height:200px;object-fit:cover" />
                                }
                                else
                                {
                                    <div style="height:200px;background:linear-gradient(135deg,var(--bg-section),rgba(212,168,83,.15));display:flex;align-items:center;justify-content:center">
                                        <i class="fa fa-newspaper fa-3x opacity-25"></i>
                                    </div>
                                }
                                <div class="p-4">
                                    @if (!string.IsNullOrEmpty(post.CategoryName))
                                    {
                                        <span class="badge rounded-pill mb-2" style="background:rgba(212,168,83,.1);color:var(--primary)">@post.CategoryName</span>
                                    }
                                    <h6 class="fw-bold text-dark mb-2">@post.Title</h6>
                                    @if (!string.IsNullOrEmpty(post.Summary))
                                    {
                                        <p class="text-muted small mb-3" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">@post.Summary</p>
                                    }
                                    <div class="d-flex align-items-center gap-3 text-muted" style="font-size:.8rem">
                                        @if (post.PublishedAt.HasValue)
                                        {
                                            <span><i class="fa fa-calendar fa-xs me-1"></i>@post.PublishedAt.Value.ToString("dd MMM yyyy")</span>
                                        }
                                        <span><i class="fa fa-clock fa-xs me-1"></i>@post.ReadTimeMinutes @Localizer["ReadTimeSuffix"]</span>
                                        <span><i class="fa fa-eye fa-xs me-1"></i>@post.ViewCount</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
            <div class="text-center mt-5 fade-up">
                <a href="/blog" class="btn-outline-modern text-decoration-none">
                    <i class="fa fa-newspaper"></i> @Localizer["ViewAllPosts"]
                </a>
            </div>
        </div>
    </section>
}
