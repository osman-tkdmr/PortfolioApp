@{
    Layout = null;
    ViewData["Title"] = "E-posta Gönderildi";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>E-posta Gönderildi – Portfolio</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        body { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .denied-card { background: rgba(255,255,255,.05); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,.1); border-radius: 20px; padding: 2.5rem; width: 100%; max-width: 420px; color: #fff; text-align: center; }
        .denied-card .icon { font-size: 3rem; color: #b0876a; }
        .btn-back { background: linear-gradient(135deg, #b0876a, #96714f); border: none; border-radius: 10px; padding: .75rem 1.5rem; font-weight: 600; color: #fff; font-size: .95rem; text-decoration: none; display: inline-block; margin-top: .5rem; }
    </style>
</head>
<body>
<div class="denied-card shadow-lg">
    <i class="fa fa-envelope-circle-check icon"></i>
    <h2 class="h4 mt-3">E-posta Gönderildi</h2>
    <p class="text-secondary">Hesabınız sistemde kayıtlıysa, şifre sıfırlama bağlantısını içeren bir e-posta gönderdik.</p>
    <a asp-controller="Account" asp-action="Login" class="btn-back"><i class="fa fa-right-to-bracket me-2"></i>Girişe Dön</a>
</div>
</body>
</html>
