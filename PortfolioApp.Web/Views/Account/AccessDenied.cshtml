@{
    Layout = null;
    ViewData["Title"] = "Erişim Reddedildi";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Erişim Reddedildi – Portfolio Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
        }
        .denied-card {
            background: rgba(255,255,255,.05); backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,.1); border-radius: 20px;
            padding: 2.5rem; width: 100%; max-width: 420px; color: #fff; text-align: center;
        }
        .denied-card .icon { font-size: 3rem; color: #b0876a; }
        .denied-card h2 { font-weight: 700; font-size: 1.5rem; margin-top: 1rem; }
        .denied-card p { color: rgba(255,255,255,.6); }
        .btn-back {
            background: linear-gradient(135deg, #b0876a, #96714f); border: none;
            border-radius: 10px; padding: .75rem 1.5rem; font-weight: 600;
            color: #fff; font-size: .95rem; transition: opacity .2s; text-decoration: none;
            display: inline-block; margin-top: .5rem;
        }
        .btn-back:hover { opacity: .9; color: #fff; }
    </style>
</head>
<body>
<div class="denied-card shadow-lg">
    <i class="fa fa-lock icon"></i>
    <h2>Erişim Reddedildi</h2>
    <p>Bu sayfayı görüntülemek için gerekli yetkiye sahip değilsiniz.</p>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <p class="small">Bu hesabın Admin yetkisi yok. Farklı bir hesapla giriş yapmak için önce çıkış yapın.</p>
        <form method="post" asp-controller="Account" asp-action="Logout">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-back border-0"><i class="fa fa-right-from-bracket me-2"></i>Çıkış Yap</button>
        </form>
    }
    else
    {
        <a asp-controller="Account" asp-action="Login" class="btn-back"><i class="fa fa-right-to-bracket me-2"></i>Giriş Sayfasına Dön</a>
    }

    <div class="mt-3">
        <a href="/" class="text-secondary small"><i class="fa fa-arrow-left me-1"></i>Siteye Dön</a>
    </div>
</div>
</body>
</html>
