@model PortfolioApp.DTO.ViewModels.Account.ResetPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Şifre Sıfırlama";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Şifre Sıfırlama – Portfolio</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        body { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { background: rgba(255,255,255,.05); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,.1); border-radius: 20px; padding: 2.5rem; width: 100%; max-width: 420px; color: #fff; }
        .form-control { background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15); color: #fff; border-radius: 10px; }
        .form-control:focus { background: rgba(255,255,255,.12); border-color: #b0876a; color: #fff; box-shadow: 0 0 0 .2rem rgba(176,135,106,.25); }
        .form-label { color: rgba(255,255,255,.7); font-size: .875rem; }
        .btn-login { background: linear-gradient(135deg, #b0876a, #96714f); border: none; border-radius: 10px; padding: .75rem; font-weight: 600; width: 100%; color: #fff; font-size: 1rem; }
    </style>
</head>
<body>
<div class="login-card shadow-lg">
    <div class="text-center mb-4">
        <i class="fa fa-lock fa-2x mb-2" style="color:#b0876a"></i>
        <h2 class="mt-2 h4">Yeni Şifre Belirle</h2>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-sm py-2">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <form method="post" asp-controller="Account" asp-action="ResetPassword">
        @Html.AntiForgeryToken()
        <input asp-for="Email" type="hidden" />
        <input asp-for="Token" type="hidden" />

        <div class="mb-3">
            <label asp-for="Password" class="form-label">Yeni Şifre</label>
            <input asp-for="Password" class="form-control" placeholder="••••••••" />
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label">Yeni Şifre (Tekrar)</label>
            <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn-login btn"><i class="fa fa-check me-2"></i>Şifreyi Sıfırla</button>
    </form>
</div>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
