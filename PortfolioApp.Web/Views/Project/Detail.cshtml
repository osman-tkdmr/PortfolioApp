@model PortfolioApp.DTO.ViewModels.Public.ProjectDetailViewModel
@{
    Layout = "~/Views/Themes/Modern/_InnerLayout.cshtml";
    ViewData["Title"] = Model.Project.Title;
    ViewData["MetaTitle"] = Model.Seo?.MetaTitle ?? Model.Project.Title;
    ViewData["MetaDescription"] = Model.Seo?.MetaDescription ?? Model.Project.ShortDescription;
    ViewData["ActiveThemeCss"] = Model.ActiveThemeCss;
}

<section class="section">
    <div class="container" style="max-width:900px">
        <a href="/projeler" class="text-decoration-none small" style="color:var(--text-muted)"><i class="fa fa-arrow-left me-1"></i>@Localizer["BackToAllProjects"]</a>

        <div class="mt-3 mb-4 fade-up">
            @if (!string.IsNullOrEmpty(Model.Project.CategoryName))
            {
                <span class="badge rounded-pill mb-2" style="background:rgba(176,135,106,.1);color:var(--primary)">@Model.Project.CategoryName</span>
            }
            <h1 class="mt-2" style="font-family:var(--font-heading);font-size:clamp(1.8rem,4vw,2.6rem)">@Model.Project.Title</h1>
            @if (!string.IsNullOrEmpty(Model.Project.ShortDescription))
            {
                <p class="text-muted">@Model.Project.ShortDescription</p>
            }
            <div class="d-flex flex-wrap align-items-center gap-3 mt-3">
                @if (!string.IsNullOrEmpty(Model.Project.DemoUrl))
                {
                    <a href="@Model.Project.DemoUrl" target="_blank" rel="noopener" class="btn-primary-modern text-decoration-none">
                        <i class="fa fa-arrow-up-right-from-square"></i> @Localizer["LiveDemo"]
                    </a>
                }
                @if (!string.IsNullOrEmpty(Model.Project.SourceUrl))
                {
                    <a href="@Model.Project.SourceUrl" target="_blank" rel="noopener" class="btn-outline-modern text-decoration-none">
                        <i class="fab fa-github"></i> @Localizer["SourceCode"]
                    </a>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Project.CoverImageUrl))
        {
            <img src="@Model.Project.CoverImageUrl" alt="@Model.Project.Title" class="w-100 mb-4 fade-up" style="border-radius:var(--radius);max-height:480px;object-fit:cover" />
        }

        @if (!string.IsNullOrEmpty(Model.Project.Description))
        {
            <div class="fade-up mb-4" style="line-height:1.9">
                @Html.Raw(Model.Project.Description)
            </div>
        }

        @if (Model.Project.Images.Count > 0)
        {
            <div class="row g-3 mb-4">
                @foreach (var image in Model.Project.Images.OrderBy(i => i.DisplayOrder))
                {
                    <div class="col-md-6">
                        <img src="@image.ImageUrl" alt="@(image.AltText ?? Model.Project.Title)" class="w-100" style="border-radius:var(--radius-sm);height:220px;object-fit:cover" />
                    </div>
                }
            </div>
        }

        <div class="row g-4 pt-4" style="border-top:1px solid var(--border)">
            @if (Model.Project.Technologies.Count > 0)
            {
                <div class="col-md-8">
                    <h6 class="fw-bold mb-2">@Localizer["TechnologiesUsed"]</h6>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var tech in Model.Project.Technologies)
                        {
                            <span class="badge rounded-pill" style="background:var(--bg-section);color:var(--text-secondary)">@tech.Name</span>
                        }
                    </div>
                </div>
            }
            <div class="col-md-4">
                @if (!string.IsNullOrEmpty(Model.Project.ClientName))
                {
                    <div class="small text-muted mb-1">@Localizer["ClientLabel"]</div>
                    <div class="fw-semibold mb-3">@Model.Project.ClientName</div>
                }
                @if (Model.Project.CompletedDate.HasValue)
                {
                    <div class="small text-muted mb-1">@Localizer["CompletedDateLabel"]</div>
                    <div class="fw-semibold">@Model.Project.CompletedDate.Value.ToString("dd MMMM yyyy")</div>
                }
            </div>
        </div>
    </div>
</section>
